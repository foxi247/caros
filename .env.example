# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — Supabase PostgreSQL (project: Carosel)
#
# Supabase Dashboard → Settings → Database → Connection string
# Use "Transaction" pooler (port 6543) for Vercel/serverless
# Use "Session" mode  (port 5432) for local dev
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE JS CLIENT
# Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Frontend (Vite — must start with VITE_)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────────────────
# JWT
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ─────────────────────────────────────────────────────────────────────────────
# URLs
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
SERVER_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# AI — NVIDIA API (meta/llama-3.3-70b-instruct)
# ─────────────────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=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

# ─────────────────────────────────────────────────────────────────────────────
# Instagram / Facebook App
# ─────────────────────────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=your-facebook-app-id
INSTAGRAM_APP_SECRET=your-facebook-app-secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/callback
