# Database — MySQL (database name: Carosel)
DATABASE_URL=mysql://root:password@localhost:3306/Carosel

# JWT Secret — used for signing auth tokens
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server
PORT=3000
SERVER_URL=http://localhost:3000

# AI / LLM (Manus Built-in LLM API)
BUILT_IN_FORGE_API_KEY=your-forge-api-key
BUILT_IN_FORGE_API_URL=https://api.manus.ai/llm

# Instagram / Facebook App (for OAuth & publishing)
INSTAGRAM_APP_ID=your-facebook-app-id
INSTAGRAM_APP_SECRET=your-facebook-app-secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/callback

# Frontend
VITE_APP_ID=instaai
