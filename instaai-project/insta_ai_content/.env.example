# ─────────────────────────────────────────────────────────────────
# DATABASE — MySQL (database name: Carosel)
# Local:       mysql://root:password@localhost:3306/Carosel
# PlanetScale: mysql://user:pass@host/Carosel?ssl={"rejectUnauthorized":true}
# Railway:     copy the connection string from Railway dashboard
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://root:password@localhost:3306/Carosel

# ─────────────────────────────────────────────────────────────────
# JWT — use a long random string (32+ chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ─────────────────────────────────────────────────────────────────
# URLs
# CLIENT_URL — your Vercel frontend URL (set after first deploy)
# SERVER_URL — only needed for local dev image serving
# ─────────────────────────────────────────────────────────────────
PORT=3000
SERVER_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173
VERCEL=          # Vercel sets this automatically to "1"

# ─────────────────────────────────────────────────────────────────
# AI / LLM (Manus built-in or OpenAI-compatible endpoint)
# ─────────────────────────────────────────────────────────────────
BUILT_IN_FORGE_API_KEY=your-api-key
BUILT_IN_FORGE_API_URL=https://api.openai.com/v1

# ─────────────────────────────────────────────────────────────────
# Cloudinary — REQUIRED for Vercel (no persistent filesystem)
# Free tier: https://cloudinary.com  → Settings → API Keys
# For local dev you can leave these empty (images saved to disk)
# ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─────────────────────────────────────────────────────────────────
# Instagram / Facebook App
# Create at: https://developers.facebook.com → My Apps → Create App
# Required permissions: instagram_basic, instagram_content_publish
# ─────────────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=your-facebook-app-id
INSTAGRAM_APP_SECRET=your-facebook-app-secret
# Set this to: https://YOUR-VERCEL-URL.vercel.app/api/instagram/callback
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/callback
