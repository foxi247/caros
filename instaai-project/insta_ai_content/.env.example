# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — Supabase PostgreSQL (project: Carosel)
#
# Get from: https://supabase.com → Project → Settings → Database → Connection string
#
# Use "Transaction" mode (port 6543) for Vercel/serverless:
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Use "Session" mode (port 5432) for local dev or persistent server:
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────────────────────────────────────────
# JWT — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ─────────────────────────────────────────────────────────────────────────────
# URLs
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
SERVER_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173
# VERCEL is set automatically by Vercel to "1"

# ─────────────────────────────────────────────────────────────────────────────
# AI — NVIDIA API (meta/llama-3.3-70b-instruct)
#
# Get your key at: https://integrate.api.nvidia.com
# ─────────────────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=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

# ─────────────────────────────────────────────────────────────────────────────
# Cloudinary — REQUIRED for Vercel (no persistent filesystem on serverless)
# Free account: https://cloudinary.com → Settings → API Keys
# Leave empty for local dev (images saved to disk instead)
# ─────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─────────────────────────────────────────────────────────────────────────────
# Instagram / Facebook App
# Create at: https://developers.facebook.com → My Apps → Create App
# Required permissions: instagram_basic, instagram_content_publish
# ─────────────────────────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=your-facebook-app-id
INSTAGRAM_APP_SECRET=your-facebook-app-secret
# For Vercel: https://YOUR-APP.vercel.app/api/instagram/callback
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/callback
